<Window x:Class="CS2AdminTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CS2 Admin Tool" Height="640" Width="900" MinWidth="840" MinHeight="560">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderThickness="1" BorderBrush="#DDD" CornerRadius="4" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Host" Margin="0,0,0,4"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Port" Margin="8,0,0,4"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Password" Margin="8,0,0,4"/>

                <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>

                <Button Grid.Row="1" Grid.Column="3"
                        Width="110"
                        Content="{Binding ConnectionButtonText}"
                        Command="{Binding ToggleConnectionCommand}"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" BorderThickness="1" BorderBrush="#DDD" CornerRadius="4" Padding="12" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="Presets"/>
                <ItemsControl ItemsSource="{Binding Presets}" Margin="0,8,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}" Margin="0,0,8,8" Padding="12,6"
                                    Command="{Binding DataContext.RunPresetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" BorderThickness="1" BorderBrush="#DDD" CornerRadius="4" Padding="12" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Margin="0,0,8,0" Text="{Binding ManualCommand, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1" Width="110" Content="Execute" Command="{Binding ExecuteCommand}"/>
            </Grid>
        </Border>

        <Border Grid.Row="3" BorderThickness="1" BorderBrush="#DDD" CornerRadius="4" Padding="12" Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" FontWeight="SemiBold" Text="Output"/>
                <ListBox Grid.Row="1" Margin="0,8,0,0" ItemsSource="{Binding LogLines}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
